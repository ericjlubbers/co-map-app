{
  "name": "co-map-worker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute co-map-db --local --file=./src/schema.sql",
    "db:migrate:remote": "wrangler d1 execute co-map-db --remote --file=./src/schema.sql"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250312.0",
    "wrangler": "^4.14.0"
  }
}
